# Doxyfile 1.9.0

# Project related configuration
PROJECT_NAME           = "Maxflow Project T9G2"
OUTPUT_DIRECTORY       = docs

# Input files
INPUT                  = main.cpp data_structures tests utils README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.c *.cpp *.h *.hpp *.md
USE_MDFILE_AS_MAINPAGE = README.md

# Extraction settings
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

# Output formats
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

# Doxygen Awesome CSS configuration
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_EXTRA_STYLESHEET  = doxygen-awesome.css
HTML_COLORSTYLE        = LIGHT

# Other options
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
WARNINGS               = YES

# Custom aliases
ALIASES += "complexity=\par Complexity:\n"
