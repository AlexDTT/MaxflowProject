digraph T23_Remove_Rev1_Rev3 {
    rankdir=LR;
    node [shape=box, style=filled, fillcolor=white, fontname="Helvetica"];
    edge [fontname="Helvetica", fontsize=9];

    // Source and Sink
    "SOURCE" [fillcolor="#ffcc80"];
    "SINK"   [fillcolor="#80cbc4"];

    // Submissions
    "SUB#1\nTopic: A" [fillcolor="#bbdefb"];
    "SUB#2\nTopic: B" [fillcolor="#bbdefb"];
    "SUB#3\nTopic: A" [fillcolor="#bbdefb"];

    // Removed reviewers shown as dashed outlines
    "REV#1\nREMOVED" [fillcolor="#ffcdd2", color="#d32f2f", style=dashed];
    "REV#2\nTopic: A" [fillcolor="#c8e6c9"];
    "REV#3\nREMOVED" [fillcolor="#ffcdd2", color="#d32f2f", style=dashed];
    "REV#4\nTopic: B" [fillcolor="#c8e6c9"];

    // Source -> Submissions
    "SOURCE" -> "SUB#1\nTopic: A" [label="1/2", color="#1976d2", penwidth=2.0];
    "SOURCE" -> "SUB#2\nTopic: B" [label="1/2", color="#1976d2", penwidth=2.0];
    "SOURCE" -> "SUB#3\nTopic: A" [label="1/2", color="#1976d2", penwidth=2.0];

    // Only remaining edges
    "SUB#1\nTopic: A" -> "REV#2\nTopic: A" [label="1/1", color=blue, penwidth=2.0];
    "SUB#3\nTopic: A" -> "REV#2\nTopic: A" [label="1/1", color=blue, penwidth=2.0];
    "SUB#2\nTopic: B" -> "REV#4\nTopic: B" [label="1/1", color=blue, penwidth=2.0];

    // Reviewers -> Sink
    "REV#2\nTopic: A" -> "SINK" [label="2/2", color="#388e3c", penwidth=2.0];
    "REV#4\nTopic: B" -> "SINK" [label="1/2", color="#388e3c", penwidth=2.0];

    // Result annotation
    label="K=2: Remove {Rev1, Rev3} -> Flow=3 < 6 -> CRITICAL";
    labelloc=b;
    fontsize=12;
    fontcolor="#d32f2f";
}
